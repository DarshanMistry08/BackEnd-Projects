<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Page</title>
<link rel="stylesheet" href="/css/home.css">
</head>

<body>
    <h1>URl-Shortener</h1>


    <div>
        <form action="/url" method="POST">
            <input style="width: 30%; margin-left: 2%; height: 25px;" type="text" name="url" placeholder="Enter URL" />
            <button style="height: 30px;" type="submit">Generate</button>


        </form>

    </div>
    <div>
        <% if (locals.urls) { %>
            <table>
                <thead>
                    <th>S.no</th>
                    <th>ShortID</th>
                    <th>RedirectURL</th>
                    <th>Click</th>
                </thead>
                <tbody>
                    <% urls.forEach((url,index)=> { %>
                        <tr>
                            <td>
                                <%= index +1 %>
                            </td>
                            <td>
                                <!-- Additional -->
                                <a href="http://localhost:3000/url/<%= url.ShortId %>"><%= url.ShortId %></a>
                                
                            </td>
                            <td>
                                <%= url.redirectURL %>
                            </td>
                            <td>
                                <%= url.visitHistory.length %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
            <% } else { %>
                <p></p>
                <% } %>

    </div>

</body>

</html>